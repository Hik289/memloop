# General API settings
MEMLOOP_API_KEY=REPLACE_ME
MEMLOOP_API_BASE_URL=https://api.example.com/v1
MEMLOOP_API_MODEL=your-chat-model

# Optional embedding API override
# MEMLOOP_EMBED_API_KEY=REPLACE_ME
# MEMLOOP_EMBED_API_BASE_URL=https://api.example.com/v1
# MEMLOOP_EMBED_API_MODEL=your-embedding-model
# MEMLOOP_EMBED_DIM=1536

# Runtime settings (see README for details)
# MEMLOOP_EMBED_BACKEND=minilm
# MEMLOOP_L0_RETRIEVAL=bm25
# MEMLOOP_SKIP_L0_EMBED=1
# MEMLOOP_ANSWER_MODE=detailed_truncated
# MEMLOOP_INDEX_CACHE_DIR=/path/to/cache
# MEMLOOP_REPO_ROOT=/path/to/this/repo
